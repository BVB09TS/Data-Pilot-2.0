# Database (matches docker-compose defaults — no changes needed for local dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_governance

# Server
SERVER_SECRET=your-secret-key-min-32-chars-here
SESSION_SECRET=your-session-secret-key
PORT=3000

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitLab (optional — omit to disable; supports self-hosted via GITLAB_BASE_URL)
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# Frontend
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3000/api

# Node
NODE_ENV=development

# ── DataPilot LLM Gateway ─────────────────────────────────────────────────────
# At least one key is required to run AI-powered audits.
# Fallback chain: premium → standard → free

# Free tier — Groq (Llama 3.1 8b) — get key at https://console.groq.com
GROQ_API_KEY=

# Standard tier — OpenAI GPT-4o-mini — get key at https://platform.openai.com
OPENAI_API_KEY=

# Premium tier — Anthropic Claude 3.5 Haiku — get key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Hourly LLM spend cap in USD (default: 1.00)
LLM_QUOTA_USD_PER_HOUR=1.00
