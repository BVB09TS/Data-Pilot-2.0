# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/datapilot

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Used to sign JWT session cookies. Generate with: openssl rand -hex 32
SERVER_SECRET=change-me-to-a-64-char-random-hex-string

# ── LLM Providers (at least one required for audit + chat to work) ─────────────
# Groq — free tier, fastest. Get key at: https://console.groq.com
GROQ_API_KEY=gsk_...

# OpenAI — standard tier (gpt-4o-mini). Optional.
# OPENAI_API_KEY=sk-...

# Anthropic — premium tier (claude-3-5-haiku). Optional.
# ANTHROPIC_API_KEY=sk-ant-...

# LLM cost cap per hour in USD (default: $1.00)
# LLM_QUOTA_USD_PER_HOUR=1.00

# ── OAuth Providers (configure at least one for production login) ─────────────

# GitHub OAuth — https://github.com/settings/developers
# Callback URL: http://localhost:3000/auth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitLab OAuth — https://gitlab.com/-/profile/applications
# Callback URL: http://localhost:3000/auth/gitlab/callback
# GITLAB_CLIENT_ID=
# GITLAB_CLIENT_SECRET=

# ── Production only ───────────────────────────────────────────────────────────
# Public-facing API URL — used to build OAuth callback URLs.
# Set this to your actual domain in production.
# API_URL=https://api.yourdomain.com

# Restrict audit project paths to this directory (path traversal protection)
# DBT_PROJECTS_DIR=/dbt_projects
